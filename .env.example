# Academic-Slides-Agent — environment template.
# Copy to `.env` and fill in your own keys. `.env` is gitignored; NEVER commit real keys.

# ── LLM provider ──────────────────────────────────────────────────────────────
# Which provider the planner/critic use: openai (OpenAI-compatible incl. local), deepseek, anthropic.
ASA_LLM_PROVIDER=deepseek

# DeepSeek (OpenAI-compatible). Get a key at https://platform.deepseek.com
ASA_DEEPSEEK_API_KEY=
ASA_DEEPSEEK_MODEL=deepseek-chat
# ASA_DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI / any OpenAI-compatible endpoint (Azure, vLLM, Ollama, aggregators…)
# ASA_OPENAI_API_KEY=
# ASA_OPENAI_BASE_URL=
# ASA_OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ASA_ANTHROPIC_API_KEY=
# ASA_ANTHROPIC_MODEL=claude-sonnet-4-6

# Sampling (optional)
# ASA_TEMPERATURE=0.2
# ASA_MAX_TOKENS=

# ── Ingestion (PDF parsing) ───────────────────────────────────────────────────
# MinerU cloud API — high-fidelity text/formula/table/figure extraction.
# Optional: without it the pipeline falls back to the local pdfplumber parser.
MINERU_API_KEY=
# MINERU_API_URL=https://mineru.net/api/v4
# Parser selection: auto (MinerU → fallbacks) | mineru | pdfplumber | docling
# ASA_PDF_PARSER=auto
# OCR language hint for MinerU (e.g. en, ch)
# ASA_MINERU_LANG=en

# ── Optional vision critic ────────────────────────────────────────────────────
# Opt-in post-render visual defect check. Needs a vision-capable model; skipped if unset.
# ASA_VLM_CRITIC=1
# ASA_VLM_MODEL=

# ── Server ────────────────────────────────────────────────────────────────────
# ASA_HOST=127.0.0.1
# ASA_PORT=8000
# ASA_OUT_DIR=exports
# ASA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# ASA_STYLE=academic
